# API Keys
NYT_API_KEY=your_nyt_api_key_here
GUARDIAN_API_KEY=your_guardian_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Paths
NARRATIO_DB_PATH=data/narratio.db
NARRATIO_EMBEDDINGS_PATH=data/embeddings.npy

# Clustering
NARRATIO_MIN_CLUSTER_SIZE=150
NARRATIO_MIN_SAMPLES=25
NARRATIO_UMAP_N_COMPONENTS=50
NARRATIO_UMAP_N_NEIGHBORS=30
NARRATIO_UMAP_MIN_DIST=0.0
NARRATIO_MERGE_THRESHOLD=0.80
NARRATIO_MATCH_THRESHOLD=0.80
NARRATIO_MAX_NARRATIVES=80
NARRATIO_RELEVANCE_THRESHOLD=0.30

# Models
NARRATIO_EMBED_MODEL=openai/text-embedding-3-small
NARRATIO_LABEL_MODEL=google/gemini-2.0-flash-001
NARRATIO_SUMMARY_MODEL=google/gemini-2.0-flash-001
NARRATIO_SENTIMENT_MODEL=google/gemini-2.0-flash-001

# Pipeline
NARRATIO_SUMMARY_TOP_N=20
NARRATIO_Z_SCORE_WINDOW=8
